# ── Supabase ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose with a NEXT_PUBLIC prefix.
SUPABASE_SERVICE_ROLE_KEY=

# ── LLM provider ──────────────────────────────────────────────────────
# This project uses Groq (free tier via console.groq.com); see agent/model.ts.
GROQ_API_KEY=
# Optional override; defaults to llama-3.3-70b-versatile
# GROQ_MODEL=

# ── Agent ─────────────────────────────────────────────────────────────
# Only used when running the agent as a separate local process (npm run agent:dev).
AGENT_SERVER_URL=http://localhost:8123
